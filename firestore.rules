rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Phase 4: Entity Validators
    function isValidObservation(data) {
      return data.keys().hasAll(['userId', 'type', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.type in ['plant', 'animal', 'study_area'] &&
             data.timestamp == request.time &&
             (data.get('notes', '') is string && data.get('notes', '').size() <= 5000);
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    // Observations Collection
    match /observations/{observationId} {
      allow create: if isVerified() && isValidId(observationId) && isValidObservation(incoming());
      
      allow get: if isOwner(existing().userId);
      allow list: if isOwner(incoming().userId); // Forced query requirement
      
      allow update: if isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      isValidObservation(incoming()) && (
                        // Limit updates to notes or species for now
                        incoming().diff(existing()).affectedKeys().hasAny(['notes', 'selectedSpecies', 'variables', 'customVariables'])
                      );
      
      allow delete: if isOwner(existing().userId);
    }

    // Users Collection
    match /users/{userId} {
      allow create: if isVerified() && isValidId(userId) && isValidUserProfile(incoming());
      allow get: if isOwner(userId);
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid && 
                      isValidUserProfile(incoming());
      allow delete: if false; // Profiles shouldn't be deleted by clients easily
    }
  }
}
